{
  "name": "@nimbus/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:visual": "node scripts/visual_route_snapshot.mjs",
    "verify:browser": "node scripts/runtime_browser_audit.mjs",
    "verify:slice": "node scripts/verify_ui_slice.mjs",
    "verify:slice:full": "node scripts/verify_ui_slice.mjs --with-visual",
    "build": "tsc -p tsconfig.json --noEmit",
    "generate:api-types": "openapi-typescript ../../openapi/openapi.yaml -o src/api/schema.d.ts",
    "dev": "vite --host 0.0.0.0 --port 13000",
    "preview": "vite preview --host 0.0.0.0 --port 13000",
    "test:visual:config": "node scripts/validate_visual_config.mjs"
  },
  "dependencies": {
    "@nimbus/ui-kit": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.4",
    "eslint-plugin-react-hooks": "^4.6.0",
    "openapi-typescript": "^7.6.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "vitest": "^2.0.5"
  }
}
